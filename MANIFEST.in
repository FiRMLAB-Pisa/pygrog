# Include documentation and configuration files
include README.rst
include LICENSE
include pyproject.toml
include setup.py
include CMakeLists.txt
include CMakePresets.json
include build_extension.sh
include build_cmake.sh

# Include CMake modules
recursive-include cmake *.cmake

# Include C++ source code
recursive-include csrc *.h *.hpp *.cpp *.c

# Include examples and documentation
recursive-include examples *.py
recursive-include docs *.md *.rst

# Include tests
recursive-include tests *.py

# Include GitHub workflows (for transparency)
recursive-include .github *.yml *.yaml

# Exclude build artifacts and caches
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.so
global-exclude *.dylib
global-exclude *.dll
global-exclude .DS_Store
global-exclude __pycache__
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .git*
recursive-exclude * build
recursive-exclude * _skbuild
recursive-exclude * dist
recursive-exclude * *.egg-info